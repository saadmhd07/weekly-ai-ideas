# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.2

# Email SMTP
# Exemple Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=ton_email@gmail.com,
# SMTP_PASSWORD=mot_de_passe_application, EMAIL_FROM=ton_email@gmail.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_TLS=true
EMAIL_FROM=from@example.com
EMAIL_TO=to@example.com
